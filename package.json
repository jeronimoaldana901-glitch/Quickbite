{
  "name": "quickbite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "patch:esbuild": "node scripts/patch-esbuild-windows.cjs",
    "predev": "npm run patch:esbuild",
    "dev": "node --require ./scripts/vite-windows-netuse-fix.cjs ./node_modules/vite/bin/vite.js --configLoader native --host 127.0.0.1 --port 5173",
    "predev:local": "npm run patch:esbuild",
    "dev:local": "node --require ./scripts/vite-windows-netuse-fix.cjs ./node_modules/vite/bin/vite.js --configLoader native --host 127.0.0.1 --port 5173 --strictPort",
    "prestart": "npm run patch:esbuild",
    "start": "node --require ./scripts/vite-windows-netuse-fix.cjs ./node_modules/vite/bin/vite.js --configLoader native --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prebuild": "npm run patch:esbuild",
    "build": "node --require ./scripts/vite-windows-netuse-fix.cjs ./node_modules/vite/bin/vite.js build --configLoader native",
    "prepreview": "npm run patch:esbuild",
    "preview": "node --require ./scripts/vite-windows-netuse-fix.cjs ./node_modules/vite/bin/vite.js preview --host 0.0.0.0",
    "supabase:connect": "node scripts/connect-supabase.mjs",
    "supabase:migrate": "node scripts/apply-migrations.mjs",
    "supabase:provision-admins": "node scripts/provision-protected-admins.mjs",
    "postinstall": "node scripts/patch-esbuild-windows.cjs",
    "prepare": "husky"
  },
  "dependencies": {
