# Application
VITE_APP_NAME=QuickBite
VITE_APP_ENV=development
VITE_PUBLIC_APP_URL=http://localhost:5173
VITE_RUNTIME_MODE=supabase
VITE_API_BASE_URL=

# Supabase - public browser values only. Never place service-role keys in Vite env vars.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_STORAGE_BUCKET=
VITE_SUPABASE_REALTIME_ENABLED=true
VITE_DATA_REFRESH_INTERVAL_MS=5000
VITE_LOYALTY_REFRESH_INTERVAL_MS=15000
VITE_PASSWORD_RESET_MODE=code

# Database/server-side values for CI, migrations or server functions. Do not expose to frontend.
SUPABASE_DB_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
PROTECTED_ADMIN_PASSWORD=
INSTALL_TOKEN=
QUICKBITE_API_PREFIX=/api
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# First-run setup
VITE_ADMIN_INVITE_CODE=
VITE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Email/notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
VITE_NOTIFICATION_PROVIDER=

# Monitoring/analytics
VITE_MONITORING_PROVIDER=console
VITE_MONITORING_DSN=
VITE_ANALYTICS_PROVIDER=none
VITE_ANALYTICS_KEY=
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=

# Domains/CDN
VITE_PRIMARY_DOMAIN=
VITE_CDN_URL=
